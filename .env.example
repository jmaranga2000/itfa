# Copy this file to .env.local and replace every placeholder with your own values.
# Do not commit real credentials or generated secrets.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=IFTA Consulting Client Portal
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/ifta
AUTH_SESSION_DAYS=14
EMAIL_VERIFICATION_TOKEN_HOURS=24
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-one-time-seed-password

# Authentication and background work
PASSWORD_PEPPER=replace-with-a-long-random-value
CRON_SECRET=replace-with-a-long-random-value

# Encryption and signed webhooks
ENCRYPTION_KEY=replace-with-a-32-byte-encryption-key
WEBHOOK_SIGNING_SECRET=replace-with-your-webhook-provider-signing-secret

# Optional AI, email, and document-storage services
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=
GMAIL_SMTP_USER=your-google-account@gmail.com
GMAIL_SMTP_APP_PASSWORD=replace-with-a-google-app-password


R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=


